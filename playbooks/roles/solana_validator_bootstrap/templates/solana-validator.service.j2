[Unit]
Description=Solana {{ cluster_environment }} node
After=network.target syslog.target
StartLimitIntervalSec=0

[Service]
Type=simple
Restart=always
RestartSec=1
User={{ solana_user }}
LimitNOFILE=2048000
LimitMEMLOCK=2000000000
#LimitCORE=infinity
StandardOutput=journal
StandardError=journal
#LogLevelMax=debug
#Environment=RUST_LOG=solana=debug
#Environment=RUST_BACKTRACE=full
#AmbientCapabilities=CAP_NET_RAW CAP_BPF CAP_NET_ADMIN CAP_PERFMON
#CapabilityBoundingSet=CAP_NET_RAW CAP_BPF CAP_NET_ADMIN CAP_PERFMON
#NoNewPrivileges=no
Environment="SOLANA_RAYON_THREADS=23"
Environment="PATH=/bin:/usr/bin:{{ env_path }}"
Environment="SOLANA_METRICS_CONFIG=host={{ solana_metrics_url }}"
{% if jito_enable %}
Environment="BLOCK_ENGINE_URL={{ jito_block_engine_url }}"
Environment="RELAYER_URL={{ jito_relayer_url }}"
Environment="BAM_URL={{ jito_bam_url }}"
Environment="SHRED_RECEIVER_ADDR={{ jito_receiver_addr }}"
Environment="SHRED_RECEIVER_ADDR_DZ=233.84.178.1:7733"
{% endif %}
#ExecStartPre=sudo ethtool -G eno1 rx 4096 tx 4096
#ExecStartPre=sudo ethtool -L eno1 combined 47
#ExecStartPre=sudo systemctl restart irqbalance.service
ExecStartPre=sudo iptables -t raw -A PREROUTING -p udp --dport {{ open_solana_ports_start }}:{{ open_solana_ports_end }} -j NOTRACK
WorkingDirectory={{ env_path }}
ExecStop={{ env_path }}/agave-validator \
--ledger {{ ledger_path }} exit --min-idle-time 2 --max-delinquent-stake 5
ExecStart={{ env_path }}/agave-validator \
--identity {{ secrets_path }}/validator-keypair.json \
--vote-account {{ secrets_path }}/vote-account-keypair.json \
--authorized-voter {{ secrets_path }}/funded-validator-keypair.json \
--rpc-port {{ solana_rpc_port }} \
--only-known-rpc \
--private-rpc \
--full-rpc-api \
--expected-genesis-hash {{ expected_genesis_hash }} \
{% for entrypoint in entrypoints %}
--entrypoint {{ entrypoint }} \
{% endfor %}
{% for known_validator in known_validators %}
--known-validator {{ known_validator }} \
{% endfor %}
--wal-recovery-mode skip_any_corrupted_record \
--limit-ledger-size \
--log {{ validator_log_path }}/solana-validator.log \
--maximum-incremental-snapshots-to-retain 2 \
--use-snapshot-archives-at-startup when-newest \
--ledger {{ ledger_path }} \
--accounts {{ accounts_path }} \
--snapshots {{ snapshots_path }} \
--accounts-index-limit minimal \
--dynamic-port-range {{ open_solana_ports_start }}-{{ open_solana_ports_end }} \
{% if jito_enable %}
--tip-payment-program-pubkey {{ jito_tip_payment_program_pubkey }} \
--tip-distribution-program-pubkey {{ jito_distribution_program_pubkey }} \
--merkle-root-upload-authority {{ jito_merkle_root_upload_authority }} \
--commission-bps {{ jito_commission_bps }} \
--relayer-url ${RELAYER_URL} \
--bam-url ${BAM_URL} \
--block-engine-url ${BLOCK_ENGINE_URL} \
--shred-receiver-address ${SHRED_RECEIVER_ADDR} \
--shred-receiver-address ${SHRED_RECEIVER_ADDR_DZ} \
{% endif %}
--expected-shred-version {{ expected_shred_version }}
--no-skip-initial-accounts-db-clean \
--experimental-poh-pinned-cpu-core 2 \
--minimal-snapshot-download-speed 60000000 \
--block-production-method central-scheduler-greedy \
--block-verification-method unified-scheduler \
--unified-scheduler-handler-threads 12 \
--trust-block-engine-packets \
--trust-relayer-packets

#--no-snapshots \
#--no-genesis-fetch \
#--no-snapshot-fetch \
#--accounts /mnt/accounts /mnt/solana/accounts \
#--account-index program-id \
#--account-index-include-key AddressLookupTab1e1111111111111111111111111 \

[Install]
WantedBy=multi-user.target
